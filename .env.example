# ── InfluxDB ────────────────────────────────────
INFLUX_TOKEN=change-me-to-a-secure-token
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=adminpassword123
INFLUX_ORG=LightMySatellite
