# ── Secrets (generate with: openssl rand -hex 32) ────────────────────
INFLUX_TOKEN=
JWT_SECRET=
INTERNAL_KEY=

# ── InfluxDB ──────────────────────────────────────────────────────────
INFLUX_ADMIN_PASSWORD=
INFLUX_ORG=LightMySatellite
INFLUX_BUCKET=slr
# INFLUX_PORT=8086

# ── Exposed ports (Caddy on host proxies to these) ───────────────────
FRONTEND_PORT=4001
BACKEND_PORT=4000
